{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext", // Configura para gerar ESModules
    "outDir": "./",
    "rootDir": "./src",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
