{
  "compilerOptions": {
    "target": "ES2020",                // Define a versão do JavaScript gerado.
    "module": "CommonJS",              // Gera módulos CommonJS.
    "outDir": "./",                // Diretório de saída para arquivos compilados.
    "rootDir": "./src",                // Diretório de origem dos arquivos TypeScript.
    "moduleResolution": "node",       // Resolve módulos no estilo Node.js.
    "esModuleInterop": true,          // Facilita importação de CommonJS no TypeScript.
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],             // Inclui todos os arquivos na pasta src.
  "exclude": ["node_modules"]          // Exclui dependências externas.
}
