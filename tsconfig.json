{
  "compilerOptions": {
    "target": "ES2022",               // Define a versão do JavaScript. Pode ser ES2020, ES2022, ESNext, etc.
    "module": "ESNext",               // Gera código com `import` e `export`.
    "outDir": "./",               // Pasta de saída para os arquivos compilados.
    "rootDir": "./src",               // Diretório raiz dos arquivos TypeScript.
    "moduleResolution": "node",      // Resolve módulos no estilo Node.js.
    "esModuleInterop": true,         // Facilita importação de CommonJS (opcional, mas recomendado).
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],            // Inclui todos os arquivos TypeScript na pasta src.
  "exclude": ["node_modules"]         // Exclui dependências externas.
}
